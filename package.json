{
  "name": "canvas-pdflib-converter",
  "version": "0.1.0",
  "description": "Converts Fabric.js canvas objects to pdf-lib PDF documents with high-fidelity vector output",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "tsup": "8.4.0",
    "typescript": "5.8.3"
  },
  "keywords": [
    "fabricjs",
    "pdf-lib",
    "pdf",
    "canvas",
    "converter",
    "fabric.js",
    "vector",
    "export"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Mr-Ashish/fabricjs-pdflib-converter.git"
  }
}
