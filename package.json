{
  "name": "canvas-pdflib-converter",
  "version": "0.1.0",
  "description": "Converts Fabric.js canvas objects to pdf-lib PDF documents with high-fidelity vector output",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:int": "vitest run tests/integration",
    "test:visual": "vitest run tests/visual",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@eslint/js": "9.24.0",
    "@pdf-lib/fontkit": "1.1.1",
    "@vitest/coverage-v8": "3.1.1",
    "eslint": "9.24.0",
    "eslint-plugin-import": "2.31.0",
    "pdf-lib": "1.17.1",
    "pdf-to-img": "^6.0.0",
    "pdf2pic": "^3.2.0",
    "pdfjs-dist": "^3.11.174",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "3.5.3",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.30.1",
    "vitest": "3.1.1"
  },
  "keywords": [
    "fabricjs",
    "pdf-lib",
    "pdf",
    "canvas",
    "converter",
    "fabric.js",
    "vector",
    "export"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Mr-Ashish/fabricjs-pdflib-converter.git"
  }
}
